{
  "mcpServers": {
    "cocos-rag": {
      "command": "uv",
      "args": [
        "run",
        "python",
        "-m",
        "src.server"
      ],
      "env": {
        "PYTHONPATH": "src",
        "OPENAI_API_KEY": "YOUR_OPENAI_API_KEY"
      },
      "cwd": "C:\\path\\to\\cocos_rag"
    }
  }
}
